{
	"name": "knownote",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.18",
		"@libsql/client": "^0.17.0",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^22",
		"better-auth": "^1.4.18",
		"daisyui": "^5.5.19",
		"drizzle-kit": "^0.31.8",
		"drizzle-orm": "^0.45.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@lucide/svelte": "^0.575.0",
		"@tiptap/core": "^3.20.1",
		"@tiptap/extension-bubble-menu": "^3.20.1",
		"@tiptap/extension-bullet-list": "^3.20.1",
		"@tiptap/extension-list-item": "^3.20.1",
		"@tiptap/extension-ordered-list": "^3.20.1",
		"@tiptap/extension-table": "^3.20.1",
		"@tiptap/extension-table-cell": "^3.20.1",
		"@tiptap/extension-table-header": "^3.20.1",
		"@tiptap/extension-table-row": "^3.20.1",
		"@tiptap/pm": "^3.20.1",
		"@tiptap/starter-kit": "^3.20.1",
		"dotenv": "^17.3.1",
		"lucide": "^0.575.0"
	}
}
